// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                String               @default("user")
  isPaid              Boolean              @default(false)
  createdAt           DateTime             @default(now())
  passwordResetTokens PasswordResetToken[]
  watchlistItems      WatchlistItem[]

  @@map("users")
}

// One row per (user, ticker) pair. `thresholdAbove` / `thresholdBelow` are
// composite-score cut-offs — an alert fires when the latest score crosses
// into the configured band from the other side. `lastNotifiedAt` stops the
// cron from spamming users on consecutive runs while the score stays above
// (or below) the threshold.
model WatchlistItem {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker          String
  thresholdAbove  Float?
  thresholdBelow  Float?
  lastScore       Float?
  lastNotifiedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, ticker])
  @@index([userId])
  @@map("watchlist_items")
}

// Stores one-use tokens for the forgot-password flow. We store the SHA-256
// hash of the token — never the token itself — so a DB breach doesn't leak
// live reset links. `expiresAt` caps the window (we use 1 hour).
// `usedAt` flips to non-null the first time the token is consumed so replays
// can't hijack a second reset.
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model Report {
  id        String   @id @default(cuid())
  title     String
  summary   String
  content   String
  createdAt DateTime @default(now())
  
  @@map("reports")
}

model News {
  id          String   @id @default(cuid())
  title       String
  content     String
  publishedAt DateTime @default(now())
  
  @@map("news")
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}
