# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (Supabase/PostgreSQL)
# Prisma uses DATABASE_URL for migrations and DIRECT_URL for direct connections.
# Get these from: Supabase dashboard -> Project Settings -> Database -> Connection string.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Security
# Generate with: openssl rand -base64 64
JWT_SECRET=<generate-with-openssl-rand-base64-64>

# CORS Configuration
# Your deployed frontend origin (comma-separated for multiple).
FRONTEND_URL=https://your-frontend-site.com

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Sentry (optional — leave blank to disable server-side error reporting).
# Get from: https://sentry.io -> [project] -> Settings -> Client Keys (DSN).
SENTRY_DSN=
