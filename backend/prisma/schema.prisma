// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                String               @default("user")
  isPaid              Boolean              @default(false)
  createdAt           DateTime             @default(now())
  // Public community-map fields. All optional; only included on the public
  // roster when locationOptIn=true AND displayName is set. lat/lng are
  // city-centroid values supplied by the curated picker on the frontend
  // — we never geocode user-typed strings server-side.
  displayName         String?
  roleTag             String?
  city                String?
  country             String?
  lat                 Float?
  lng                 Float?
  locationOptIn       Boolean              @default(false)
  passwordResetTokens PasswordResetToken[]
  watchlistItems      WatchlistItem[]
  referralCode        ReferralCode?
  referralsMade       ReferralRedemption[] @relation("ReferralsMade")
  referralReceived    ReferralRedemption?  @relation("ReferralReceived")

  @@map("users")
}

// One code per user, generated on first access to the "invite friends" UI.
// Human-readable (e.g. JOE-9K3Q) so people can type it from a phone screen,
// not just click links. `usageCount` is denormalised for read-heavy displays
// so we don't JOIN redemptions every time the dashboard renders.
model ReferralCode {
  id         String   @id @default(cuid())
  code       String   @unique
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())

  redemptions ReferralRedemption[]

  @@map("referral_codes")
}

// One redemption per referred user. `referrerId` denormalises the owner of
// the code so queries for "my referrals" don't need a three-table JOIN.
// `rewardGrantedAt` flips when we actually issue the free month (i.e. the
// referred user starts paying) — separating capture from reward avoids
// premature payouts on free signups.
model ReferralRedemption {
  id              String    @id @default(cuid())
  codeId          String
  code            ReferralCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  referrerId      String
  referrer        User      @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId  String    @unique
  referredUser    User      @relation("ReferralReceived", fields: [referredUserId], references: [id], onDelete: Cascade)
  rewardGrantedAt DateTime?
  createdAt       DateTime  @default(now())

  @@index([referrerId])
  @@index([codeId])
  @@map("referral_redemptions")
}

// One row per (user, ticker) pair. `thresholdAbove` / `thresholdBelow` are
// composite-score cut-offs — an alert fires when the latest score crosses
// into the configured band from the other side. `lastNotifiedAt` stops the
// cron from spamming users on consecutive runs while the score stays above
// (or below) the threshold.
model WatchlistItem {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker          String
  thresholdAbove  Float?
  thresholdBelow  Float?
  lastScore       Float?
  lastNotifiedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, ticker])
  @@index([userId])
  @@map("watchlist_items")
}

// Stores one-use tokens for the forgot-password flow. We store the SHA-256
// hash of the token — never the token itself — so a DB breach doesn't leak
// live reset links. `expiresAt` caps the window (we use 1 hour).
// `usedAt` flips to non-null the first time the token is consumed so replays
// can't hijack a second reset.
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model Report {
  id        String   @id @default(cuid())
  title     String
  summary   String
  content   String
  createdAt DateTime @default(now())
  
  @@map("reports")
}

model News {
  id          String   @id @default(cuid())
  title       String
  content     String
  publishedAt DateTime @default(now())
  
  @@map("news")
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

// Pre-launch waitlist applications. Captured before Stripe is wired up so
// the team can manually invite approved institutional traders to the live
// product. Migrated in from the standalone preregister site so signup
// state lives in one place.
model WaitlistEntry {
  id          String   @id @default(cuid())
  email       String   @unique
  fullName    String
  institution String?
  aum         String?
  source      String?  // e.g. "screening" / "homepage-cta" — for funnel attribution
  userAgent   String?
  ipAddress   String?
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("waitlist_entries")
}
