// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                String               @default("user")
  isPaid              Boolean              @default(false)
  createdAt           DateTime             @default(now())
  // Public community-map fields. All optional; only included on the public
  // roster when locationOptIn=true AND displayName is set. lat/lng are
  // city-centroid values supplied by the curated picker on the frontend
  // — we never geocode user-typed strings server-side.
  displayName         String?
  roleTag             String?
  city                String?
  country             String?
  lat                 Float?
  lng                 Float?
  locationOptIn       Boolean              @default(false)
  // TOTP-based 2FA. totpSecret is set the moment a user starts setup;
  // totpEnabled flips only after they confirm a valid code, so an
  // abandoned setup never locks anyone out. Backup codes are bcrypt
  // hashes — one entry per code, spliced out on redemption.
  totpSecret          String?
  totpEnabled         Boolean              @default(false)
  totpBackupCodes     String[]             @default([])
  // Set the moment the user finishes the first-run wizard. Null means
  // they haven't yet, so the frontend redirects them on next login.
  // Existing users were backfilled to createdAt by migration 008.
  onboardedAt         DateTime?
  // Telegram delivery channel. Set when the user clicks "Connect" in
  // Settings and hits /start in the bot with a one-time linking token;
  // cleared when they disconnect. Username is cosmetic — we deliver to
  // chatId, which is stable. Both null = no Telegram alerts.
  telegramChatId      String?
  telegramUsername    String?
  // Webhook delivery for watchlist alerts. URL is what we POST to;
  // secret is the HMAC-SHA256 key for the X-ChartSentinel-Signature
  // header. failureCount/disabledAt drive automatic backoff after
  // three consecutive POST failures.
  webhookUrl          String?
  webhookSecret       String?
  webhookFailureCount Int                  @default(0)
  webhookDisabledAt   DateTime?
  // Per-user composite weights as JSON ({ seasonal, cot, pattern, base }).
  // Null = use the default 0.30/0.25/0.30/0.15 blend. Server normalises
  // to sum to 1.0 before scoring so a user-supplied (40, 40, 40, 0) still
  // works (gets re-scaled to (0.333, 0.333, 0.333, 0)).
  signalWeights       Json?
  passwordResetTokens PasswordResetToken[]
  watchlistItems      WatchlistItem[]
  portfolios          Portfolio[]
  referralCode        ReferralCode?
  referralsMade       ReferralRedemption[] @relation("ReferralsMade")
  referralReceived    ReferralRedemption?  @relation("ReferralReceived")

  @@map("users")
}

// Named basket of holdings — lets a user define an actual portfolio and
// get a weighted composite score across it. Cascade delete from User so
// account closure tears the portfolio down with it.
// Short opaque tokens for the Telegram /start linking flow. Telegram caps
// the /start parameter at 64 chars [A-Za-z0-9_-]; a signed JWT can't
// fit, so we hand out a random 24-char id and look it up here. Rows are
// deleted on consume; expired rows are swept lazily on the next
// consume-like read.
model TelegramLinkToken {
  token     String   @id
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
  @@map("telegram_link_tokens")
}

model Portfolio {
  id        String          @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     PortfolioItem[]

  @@index([userId])
  @@map("portfolios")
}

// Child row: (ticker, weight) inside a portfolio. Weight is a raw
// decimal; the aggregator normalises before scoring. unique(portfolioId,
// ticker) prevents duplicate holdings of the same instrument.
model PortfolioItem {
  id          String    @id @default(cuid())
  portfolioId String
  ticker      String
  weight      Float
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, ticker])
  @@index([portfolioId])
  @@map("portfolio_items")
}

// One row per execution of a scheduled job (weekly digest, watchlist alert
// checker). Inserted only at completion — anything mid-flight is invisible
// here. Powers the admin "did the digest go out last Friday?" view without
// anyone needing to read Railway / cron logs.
model JobRun {
  id         String   @id @default(cuid())
  name       String
  status     String
  startedAt  DateTime
  finishedAt DateTime
  durationMs Int
  message    String?
  metadata   Json?

  @@index([name, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
  @@map("job_runs")
}

// Append-only history of security-relevant events: logins, 2FA enrolment,
// password resets, eventually destructive admin operations. Not authoritative
// state — just a forensic record. No FK relation to User on purpose so
// deleting a user doesn't cascade away their audit trail.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  event     String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([event, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// One code per user, generated on first access to the "invite friends" UI.
// Human-readable (e.g. JOE-9K3Q) so people can type it from a phone screen,
// not just click links. `usageCount` is denormalised for read-heavy displays
// so we don't JOIN redemptions every time the dashboard renders.
model ReferralCode {
  id         String   @id @default(cuid())
  code       String   @unique
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())

  redemptions ReferralRedemption[]

  @@map("referral_codes")
}

// One redemption per referred user. `referrerId` denormalises the owner of
// the code so queries for "my referrals" don't need a three-table JOIN.
// `rewardGrantedAt` flips when we actually issue the free month (i.e. the
// referred user starts paying) — separating capture from reward avoids
// premature payouts on free signups.
model ReferralRedemption {
  id              String       @id @default(cuid())
  codeId          String
  code            ReferralCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  referrerId      String
  referrer        User         @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId  String       @unique
  referredUser    User         @relation("ReferralReceived", fields: [referredUserId], references: [id], onDelete: Cascade)
  rewardGrantedAt DateTime?
  createdAt       DateTime     @default(now())

  @@index([referrerId])
  @@index([codeId])
  @@map("referral_redemptions")
}

// One row per (user, ticker) pair. `thresholdAbove` / `thresholdBelow` are
// composite-score cut-offs — an alert fires when the latest score crosses
// into the configured band from the other side. `lastNotifiedAt` stops the
// cron from spamming users on consecutive runs while the score stays above
// (or below) the threshold.
model WatchlistItem {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker         String
  thresholdAbove Float?
  thresholdBelow Float?
  lastScore      Float?
  lastNotifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, ticker])
  @@index([userId])
  @@map("watchlist_items")
}

// Stores one-use tokens for the forgot-password flow. We store the SHA-256
// hash of the token — never the token itself — so a DB breach doesn't leak
// live reset links. `expiresAt` caps the window (we use 1 hour).
// `usedAt` flips to non-null the first time the token is consumed so replays
// can't hijack a second reset.
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model Report {
  id        String   @id @default(cuid())
  title     String
  summary   String
  content   String
  createdAt DateTime @default(now())

  @@map("reports")
}

model News {
  id          String   @id @default(cuid())
  title       String
  content     String
  publishedAt DateTime @default(now())

  @@map("news")
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

// Pre-launch waitlist applications. Captured before Stripe is wired up so
// the team can manually invite approved institutional traders to the live
// product. Migrated in from the standalone preregister site so signup
// state lives in one place.
model WaitlistEntry {
  id          String   @id @default(cuid())
  email       String   @unique
  fullName    String
  institution String?
  aum         String?
  source      String? // e.g. "screening" / "homepage-cta" — for funnel attribution
  userAgent   String?
  ipAddress   String?
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("waitlist_entries")
}
