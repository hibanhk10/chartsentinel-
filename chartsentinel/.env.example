VITE_API_URL=http://localhost:3000/api
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Sentry (optional — leave blank to disable client-side error reporting).
# Get from: https://sentry.io -> [project] -> Settings -> Client Keys (DSN).
VITE_SENTRY_DSN=

# PostHog (optional — leave blank until the account is created; the analytics
# module no-ops without a key so there are zero outbound requests).
# VITE_POSTHOG_HOST defaults to https://us.i.posthog.com — set to https://eu.i.posthog.com
# if the project lives in the EU cloud.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
